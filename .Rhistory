type_line_parse <- function(data)
{
# data = data_simpl
padding = rep(list(NA), nrow(data))
supertype_list = c("Basic", "Legendary", "Ongoing", "Snow", "World", "Elite", "Host")
type_lines <-
data$type_line %>%
str_split_i(" // ",1) %>%
str_split(" — ") %>%
mapply(append, ., padding, SIMPLIFY = FALSE)
subtypes <-
type_lines %>%
sapply("[[", 2) %>%
str_split(" ")
pretype <-
type_lines %>%
sapply("[[", 1) %>%
str_split_fixed(" ", n = 99)
pretype <- pretype[, colSums(pretype != "") != 0]
supertype_l <- matrix(pretype %in% supertype_list, nrow = nrow(pretype), ncol = ncol(pretype))
supertypes <- matrix("", nrow = nrow(pretype), ncol = ncol(pretype))
supertypes[supertype_l] <- pretype[supertype_l]
supertypes <-
supertypes %>%
split(row(supertypes)) %>%
sapply(FUN = function(x) x[x!=""])
type_l <- !supertype_l
types <- matrix("", nrow = nrow(pretype), ncol = ncol(pretype))
types[type_l] <- pretype[type_l]
types <-
types %>%
split(row(types)) %>%
sapply(FUN = function(x) x[x!=""])
return(cbind(data,tibble(supertypes, types, subtypes)))
}
generic_find <- function(data, field, search, not = FALSE, thresh = 1)
{
if(thresh < 1)
{
thresh = length(search)
}
if(not)
{
data %>%
filter(!sapply({{field}}, function(x) sum(search %in% x)>=thresh)) %>%
return()
} else {
data %>%
filter(sapply({{field}}, function(x) sum(search %in% x)>=thresh)) %>%
return()
}
}
color_invert <- function(my_cols)
{
mtg_cols <- c("W","U","B","R","G")
return(mtg_cols[!(mtg_cols %in% my_cols)])
}
color_contains_any <- function(data, my_cols)
{
data %>%
generic_find(color_identity,my_cols) %>%
return()
}
color_at_most <- function(data, my_cols)
{
data %>%
generic_find(color_identity,color_invert(my_cols), TRUE) %>%
return()
}
color_at_least <- function(data, my_cols)
{
data %>%
generic_find(color_identity,my_cols,thresh = -1) %>%
return()
}
color_exactly <- function(data, my_cols)
{
data %>%
color_at_most(my_cols) %>%
color_at_least(my_cols) %>%
return()
}
name_clean <- function(data)
{
data %>%
select(name) %>%
mutate(name = str_remove_all(name,"\"")) %>%
unlist() %>%
str_split_i(" // ",1) %>%
return()
}
legal_filter <- function(data)
{
data %>%
filter(legalities$vintage | legalities$timeless | legalities$commander | legalities$brawl | legalities$alchemy) %>%
return()
}
slice_pack <- function(data, common = 0, uncommon = 0, rare = 0, mythic = 0, random = 0, set = "")
{
if(set != "")
{
data <-
data %>%
filter(set_id == set)
}
common_cards <-
data %>%
filter(rarity == "common") %>%
slice_sample(n=common)
uncommon_cards <-
data %>%
filter(rarity == "uncommon") %>%
slice_sample(n=uncommon)
rare_cards <-
data %>%
filter(rarity == "rare") %>%
slice_sample(n=rare)
mythic_cards <-
data %>%
filter(rarity == "mythic") %>%
slice_sample(n=mythic)
random_cards <-
data %>%
slice_sample(n=random)
rbind(common_cards, uncommon_cards, rare_cards, mythic_cards, random_cards) %>%
return()
}
not_land <- function(data)
{
data %>%
generic_find(types,"Land",not=TRUE) %>%
return()
}
land <- function(data)
{
data %>%
generic_find(types,"Land") %>%
return()
}
clean_display <- function(my_names)
{
my_names[length(my_names)] <- paste(my_names[length(my_names)],'\n\n', sep = '')
my_names[1] <- paste('\n\n',my_names[1],sep='')
print(paste(my_names, collapse = '\n') %>% cat())
# return(names)
}
rarity_rank_filter<- function(data, prop = 0.5)
{
common_cards <-
data %>%
filter(rarity == "common")
common_cutoff <-
common_cards %>%
quantile()
uncommon_cards <-
data %>%
filter(rarity == "uncommon")
rare_cards <-
data %>%
filter(rarity == "rare")
mythic_cards <-
data %>%
filter(rarity == "mythic")
rbind(common_cards, uncommon_cards, rare_cards, mythic_cards, random_cards) %>%
return()
}
