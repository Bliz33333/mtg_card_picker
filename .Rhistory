slice_pack <- function(data, common = 0, uncommon = 0, rare = 0, mythic = 0, random = 0)
{
common_cards <-
data %>%
filter(rarity == "common") %>%
slice_sample(n=common)
uncommon_cards <-
data %>%
filter(rarity == "uncommon") %>%
slice_sample(n=uncommon)
rare_cards <-
data %>%
filter(rarity == "rare") %>%
slice_sample(n=rare)
mythic_cards <-
data %>%
filter(rarity == "mythic") %>%
slice_sample(n=mythic)
random_cards <-
data %>%
slice_sample(n=random)
rbind(common, uncommon, rare, mythic, random) %>%
return()
}
